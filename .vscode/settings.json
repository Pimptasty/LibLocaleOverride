{
    "Lua.runtime.version": "Lua 5.1",
    "Lua.runtime.builtin": {
        "basic": "disable",
        "debug": "disable",
        "io": "disable",
        "math": "disable",
        "os": "disable",
        "package": "disable",
        "string": "disable",
        "table": "disable",
        "utf8": "disable"
    },
    "Lua.workspace.library": [
        "~\\.vscode\\extensions\\ketho.wow-api-0.22.3\\Annotations\\Core"
    ],
    "Lua.workspace.ignoreDir": [
        ".vscode",
        "libs"
    ],
    "Lua.diagnostics.globals": [
        "LibStub",
        "GetLocale",
        "CreateFont"
    ],
    "Lua.diagnostics.disable": [
        "assign-type-mismatch"
    ],
    "Lua.type.weakUnionCheck": true,
    "markdownlint.ignore": [
        ".pkgmeta"
    ],
    "files.associations": {
        ".pkgmeta": "yaml"
    }
}
