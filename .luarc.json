{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "runtime.version": "Lua 5.1",
  "diagnostics.globals": [
    "LibStub",
    "GetLocale",
    "CreateFont",
    "strmatch",
    "table",
    "string",
    "pairs",
    "ipairs",
    "type",
    "tostring",
    "tonumber",
    "next",
    "select",
    "assert",
    "error",
    "setmetatable",
    "rawget",
    "_G"
  ],
  "diagnostics.disable": [
    "lowercase-global",
    "undefined-global",
    "trailing-space",
    "undefined-field"
  ],
  "workspace.ignoreDir": [
    ".vscode",
    "libs"
  ],
  "workspace.library": [],
  "completion.enable": true,
  "hint.enable": true,
  "type.castNumberToInteger": true
}
